# PEPPER ST. dashboard — environment example (Slice 3).
# Copy to .env (gitignored) and fill real values. NEVER commit real secrets.

# PostgreSQL connection — used ONLY server-side (migrate / seed / verify / server
# components). This is the same database that hosts the read-only `ai.*` schema;
# this app only ever writes the `dashboard` schema.
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DATABASE

# Demo tenant resolver (Phase 1, no auth). Defaults to "pepper-st" if unset.
DEMO_TENANT_SLUG=pepper-st
